#!/usr/bin/env bash
# git-unported — show commits on MAIN not yet in RELEASE
# excludes: (1) -x cherry-pick trailers on release (wins on conflict)
#           (2) same stable patch-id on release AND same trimmed first subject line
# runs on root repo and all submodules
#
# Usage: git-unported [options] [main-branch] [release-branch] [remote]
# Defaults: main  release/1.0  origin

set -euo pipefail

CONVENTIONAL_ONLY=0
FEAT_FIX_ONLY=0
POS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --conventional-only | -c) CONVENTIONAL_ONLY=1; shift ;;
    --feat-fix-only | -F) FEAT_FIX_ONLY=1; shift ;;
    -h | --help)
      cat <<'EOF'
Usage: git-unported [options] [main-branch] [release-branch] [remote]

  --conventional-only, -c   list only conventional commits (feat:, fix:, docs:, …)
  --feat-fix-only, -F     list only feat: and fix: (including feat!/fix! and optional scope)
  -h, --help              show this help

Defaults: main  release/1.0  origin
EOF
      exit 0
      ;;
    *) POS+=("$1"); shift ;;
  esac
done

MAIN="${POS[0]:-main}"
RELEASE="${POS[1]:-release/1.0}"
REMOTE="${POS[2]:-origin}"

BOLD=$'\e[1m'
DIM=$'\e[2m'
RESET=$'\e[0m'
CYAN=$'\e[36m'
YELLOW=$'\e[33m'
GREEN=$'\e[32m'
MAGENTA=$'\e[35m'
RED=$'\e[31m'

# Non-blank body lines to print after the subject (rest is truncated with "…")
BODY_LINES_MAX=4

strip_body_edges() {
  local s=$1
  while [[ "$s" == $'\n'* ]]; do s="${s#$'\n'}"; done
  while [[ "$s" == *$'\n' ]]; do s="${s%$'\n'}"; done
  printf '%s' "$s"
}

# Normalized subject for matching across branches (case, whitespace, CR, trailing PR refs)
normalize_subject_key() {
  printf '%s' "$1" | LC_ALL=C tr -d '\r' | LC_ALL=C tr '[:upper:]' '[:lower:]' \
    | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/[[:space:]]\{1,\}/ /g' \
    | sed -e :a -e 's/[[:space:]]*[(]#[0-9][0-9]*[)]$//' -e ta
}

# First line matches Conventional Commits (type, optional scope, optional !, : description).
# Allows a space before "(" (e.g. "fix (scope): …" as well as "fix(scope): …").
# (regex in a variable — bash [[ =~ ]] misparses some nested-paren patterns when inlined)
is_conventional() {
  local re='^[a-z][a-z0-9]*[[:space:]]*(\([^)]*\))?(!)?:[[:space:]]*'
  [[ "$1" =~ $re ]]
}

# Conventional type is exactly feat or fix (scope / ! allowed, same spacing rules as is_conventional)
is_feat_or_fix() {
  local re='^([a-z][a-z0-9]*)([[:space:]]*\([^)]*\))?(!)?:'
  [[ "$1" =~ $re ]] || return 1
  case "${BASH_REMATCH[1]}" in
    feat | fix) return 0 ;;
    *) return 1 ;;
  esac
}

# Colorize the first line when it is conventional (type token highlighted by category)
format_conv_first_line() {
  local line="$1"
  local re='^([a-z][a-z0-9]*)([[:space:]]*\([^)]*\))?(!)?(:)[[:space:]]*(.*)$'
  if [[ "$line" =~ $re ]]; then
    local typ="${BASH_REMATCH[1]}"
    local scope_bang="${BASH_REMATCH[2]}${BASH_REMATCH[3]}${BASH_REMATCH[4]}"
    local desc="${BASH_REMATCH[5]}"
    local tc
    case "$typ" in
      feat) tc="${BOLD}${GREEN}" ;;
      fix | perf) tc="${BOLD}${YELLOW}" ;;
      revert) tc="${BOLD}${RED}" ;;
      doc | docs) tc="${BOLD}${CYAN}" ;;
      test | build | ci) tc="${MAGENTA}" ;;
      chore | style) tc="${DIM}" ;;
      refactor) tc="${CYAN}" ;;
      *) tc="${BOLD}" ;;
    esac
    echo -n "${tc}${typ}${RESET}${scope_bang} ${desc}"
  else
    echo -n "$line"
  fi
}

print_commit_block() {
  local hash="$1" date="$2" author="$3" message="$4" mode="$5"
  local first rest
  author="${author:0:20}"

  if [[ "$message" == *$'\n'* ]]; then
    first="${message%%$'\n'*}"
    rest="${message#*$'\n'}"
  else
    first="$message"
    rest=""
  fi

  rest=$(strip_body_edges "$rest")
  [[ "$rest" =~ ^[[:space:]]*$ ]] && rest=""

  printf "  ${YELLOW}%-10s${RESET}  ${DIM}%-11s${RESET}  ${GREEN}%-22s${RESET}  " \
    "$hash" "$date" "$author"

  if [[ "$mode" == conv ]]; then
    echo "$(format_conv_first_line "$first")${RESET}"
  else
    echo "${DIM}${first}${RESET}"
  fi

  if [[ -n "$rest" ]]; then
    local shown=0 total_nb=0
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ "$line" =~ ^[[:space:]]*$ ]] && continue
      # Omit git's -x trailer when it appears in the source commit message (noise for release notes)
      [[ "$line" =~ ^[[:space:]]*\(cherry[[:space:]]picked[[:space:]]from[[:space:]]commit[[:space:]]+[0-9a-f]+\)[[:space:]]*$ ]] && continue
      total_nb=$((total_nb + 1))
      if ((shown < BODY_LINES_MAX)); then
        if [[ "$mode" == conv ]]; then
          printf "  ${YELLOW}%-10s${RESET}  ${DIM}%-11s${RESET}  ${GREEN}%-22s${RESET}  ${DIM}%s${RESET}\n" \
            "" "" "" "$line"
        else
          printf "  ${DIM}%-10s  %-11s  %-22s  %s${RESET}\n" "" "" "" "$line"
        fi
        shown=$((shown + 1))
      fi
    done <<< "$rest"
    if ((total_nb > BODY_LINES_MAX)); then
      if [[ "$mode" == conv ]]; then
        printf "  ${YELLOW}%-10s${RESET}  ${DIM}%-11s${RESET}  ${GREEN}%-22s${RESET}  ${DIM}… (truncated)${RESET}\n" \
          "" "" ""
      else
        printf "  ${DIM}%-10s  %-11s  %-22s  … (truncated)${RESET}\n" "" "" ""
      fi
    fi
  fi
}

check_repo() {
  local label="$1"
  local fullpath="$2"
  local main="$3"
  local release="$4"

  git fetch "$REMOTE" --quiet 2>/dev/null || true

  local mb="$REMOTE/$main"
  local rb="$REMOTE/$release"

  git rev-parse --verify "$mb" &>/dev/null || mb="$main"
  git rev-parse --verify "$rb" &>/dev/null || rb="$release"

  if ! git rev-parse --verify "$mb" &>/dev/null; then
    echo "${DIM}  skipping $label — branch $main not found${RESET}"
    return
  fi
  if ! git rev-parse --verify "$rb" &>/dev/null; then
    echo "${DIM}  skipping $label — branch $release not found${RESET}"
    return
  fi

  local ported
  ported=$(git log "$rb" --format="%B" \
    | grep -oE '\(cherry picked from commit [0-9a-f]+\)' \
    | grep -oE '[0-9a-f]{7,}' || true)

  # Scan release: (1) patch-id -> subjects, (2) set of normalized subjects (same line landed on release).
  # Optional: PATCH_ID_INDEX_MAX=N limits how many release commits are scanned (newest first).
  local -A rel_patch_subj=()
  local -A rel_norm_subj=()
  local rh pid subj nk rev_extra
  if [[ "${PATCH_ID_INDEX_MAX:-}" =~ ^[0-9]+$ ]] && ((PATCH_ID_INDEX_MAX > 0)); then
    rev_extra=(--max-count="$PATCH_ID_INDEX_MAX")
  else
    rev_extra=()
  fi
  while read -r rh; do
    [[ -z "$rh" ]] && continue
    subj=$(git log -1 --format=%s "$rh" 2>/dev/null)
    [[ -z "$subj" ]] && continue
    nk=$(normalize_subject_key "$subj")
    if [[ -n "$nk" ]]; then
      rel_norm_subj["$nk"]=1
    fi
    pid=$(git show "$rh" --no-textconv -p --pretty=format: 2>/dev/null | git patch-id --stable 2>/dev/null | awk '{print $1}')
    [[ -z "$pid" ]] && continue
    if [[ -n "${rel_patch_subj[$pid]:-}" ]]; then
      rel_patch_subj["$pid"]+=$'\n'"$subj"
    else
      rel_patch_subj["$pid"]="$subj"
    fi
  done < <(git rev-list "${rev_extra[@]}" "$rb" 2>/dev/null || true)

  local -a ch=() cd=() ca=() cm=()
  local -a oh=() od=() oa=() om=()

  # Use \x1e between fields: --format cannot contain NUL (C string). -z still NUL-terminates each commit record.
  local RS=$'\x1e'

  while IFS= read -r -d '' record; do
    local r hash date author message
    r=$record
    hash="${r%%"$RS"*}"
    r="${r#*"$RS"}"
    date="${r%%"$RS"*}"
    r="${r#*"$RS"}"
    author="${r%%"$RS"*}"
    message="${r#*"$RS"}"

    local full_hash
    full_hash=$(git rev-parse "$hash" 2>/dev/null || echo "")

    if [[ -n "$ported" && -n "$full_hash" ]]; then
      if echo "$ported" | grep -qF "${full_hash:0:12}"; then
        continue
      fi
    fi

    local first_line="${message%%$'\n'*}"

    if [[ -n "$full_hash" ]]; then
      local cpid ct st s_line match_pm=0
      cpid=$(git show "$full_hash" --no-textconv -p --pretty=format: 2>/dev/null | git patch-id --stable 2>/dev/null | awk '{print $1}')
      if [[ -n "$cpid" && -n "${rel_patch_subj[$cpid]:-}" ]]; then
        ct=$(normalize_subject_key "$first_line")
        while IFS= read -r s_line || [[ -n "$s_line" ]]; do
          st=$(normalize_subject_key "$s_line")
          [[ -n "$ct" && "$st" == "$ct" ]] && match_pm=1 && break
        done <<< "${rel_patch_subj[$cpid]}"
        if ((match_pm)); then
          continue
        fi
      fi
    fi

    # Same subject already exists on release (handles cherry-picks where patch-id differs).
    if [[ "${SUBJECT_DEDUP:-1}" != "0" ]]; then
      nk=$(normalize_subject_key "$first_line")
      if [[ -n "$nk" && -n "${rel_norm_subj[$nk]+x}" ]]; then
        continue
      fi
    fi

    if is_conventional "$first_line"; then
      if ((FEAT_FIX_ONLY)) && ! is_feat_or_fix "$first_line"; then
        continue
      fi
      ch+=("$hash")
      cd+=("$date")
      ca+=("$author")
      cm+=("$message")
    else
      ((FEAT_FIX_ONLY)) && continue
      oh+=("$hash")
      od+=("$date")
      oa+=("$author")
      om+=("$message")
    fi
  done < <(git log "$mb" --not "$rb" -z --format="%h${RS}%ad${RS}%an${RS}%B" --date=short 2>/dev/null || true)

  local n_conv=${#ch[@]}
  local n_other=${#oh[@]}
  ((n_conv + n_other == 0)) && return
  ((CONVENTIONAL_ONLY && n_conv == 0)) && return
  ((FEAT_FIX_ONLY && n_conv == 0)) && return

  local rule_w="${COLUMNS:-120}"
  ((rule_w < 88)) && rule_w=88
  local rule_line
  rule_line=$(printf '%*s' "$rule_w" '' | tr ' ' '─')

  echo ""
  if [[ "$label" == "root" ]]; then
    echo "${BOLD}${CYAN}● root repo${RESET}"
  else
    echo "${BOLD}${CYAN}● submodule: ${label}${RESET}  ${DIM}(${fullpath})${RESET}"
  fi
  echo "${DIM}${rule_line}${RESET}"
  printf "${DIM}  %-10s  %-11s  %-22s  %s${RESET}\n" "hash" "date" "author" "message"
  echo "${DIM}${rule_line}${RESET}"

  local i
  if ((n_conv > 0 && n_other > 0 && CONVENTIONAL_ONLY == 0)); then
    echo ""
    echo "${BOLD}  Conventional commits${RESET}  ${DIM}(feat, fix, docs, …)${RESET}"
    echo "${DIM}${rule_line}${RESET}"
  fi

  for ((i = 0; i < n_conv; i++)); do
    print_commit_block "${ch[i]}" "${cd[i]}" "${ca[i]}" "${cm[i]}" conv
  done

  if ((n_other > 0 && CONVENTIONAL_ONLY == 0)); then
    echo ""
    if ((n_conv > 0)); then
      echo "${DIM}  Other commits${RESET}  ${DIM}(no conventional prefix; often minor)${RESET}"
    else
      echo "${DIM}  Other commits${RESET}  ${DIM}(no feat/fix/docs/… prefix)${RESET}"
    fi
    echo "${DIM}${rule_line}${RESET}"
    for ((i = 0; i < n_other; i++)); do
      print_commit_block "${oh[i]}" "${od[i]}" "${oa[i]}" "${om[i]}" other
    done
  fi
}

# Resolve the repo whose .gitmodules we should read. If the shell cwd is inside a
# submodule, `git rev-parse --show-toplevel` is that submodule only — no .gitmodules,
# so sibling submodules are never scanned. Prefer the superproject when it exists.
HERE_TOP=$(git rev-parse --show-toplevel)
SUPER=$(git rev-parse --show-superproject-working-tree 2>/dev/null || true)
if [[ -n "$SUPER" && -f "$SUPER/.gitmodules" ]]; then
  REPO_ROOT=$SUPER
else
  REPO_ROOT=$HERE_TOP
fi
cd "$REPO_ROOT" || {
  echo "cannot cd to repo root: $REPO_ROOT" >&2
  exit 1
}

echo ""
echo "${BOLD}Unported commits${RESET}  ${CYAN}${MAIN}${RESET} → not in ${CYAN}${RELEASE}${RESET}"
echo "${DIM}Excluded: -x trailers (win on conflict); same patch-id + subject on release; or same normalized subject as any commit on release (set SUBJECT_DEDUP=0 to disable the last).${RESET}"
if ((CONVENTIONAL_ONLY)); then
  echo "${DIM}Showing conventional commits only (use without --conventional-only to include the rest).${RESET}"
fi
if ((FEAT_FIX_ONLY)); then
  echo "${DIM}Showing only feat: and fix: (use without --feat-fix-only to include other types).${RESET}"
fi

# root repo
check_repo "root" "." "$MAIN" "$RELEASE"

# read submodule paths directly from .gitmodules
if [[ -f "$REPO_ROOT/.gitmodules" ]]; then
  while IFS= read -r subpath; do
    [[ -z "$subpath" ]] && continue
    # strip CR from .gitmodules on Windows-style checkouts
    subpath="${subpath//$'\r'/}"
    local_path="$REPO_ROOT/$subpath"
    if ! git -C "$local_path" rev-parse --is-inside-work-tree &>/dev/null; then
      echo "${DIM}  skipping submodule ${subpath} — not a git checkout${RESET}"
      continue
    fi
    subname=$(basename "$subpath")
    (
      cd "$local_path"
      check_repo "$subname" "$subpath" "$MAIN" "$RELEASE"
    )
  done < <(git config --file "$REPO_ROOT/.gitmodules" --get-regexp '^submodule\..*\.path$' \
    | awk '{print $2}')
fi

echo ""
